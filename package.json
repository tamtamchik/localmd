{
  "name": "@tamtamchik/localmd",
  "version": "1.0.0",
  "description": "Serve any folder as a local markdown editor with live preview",
  "type": "module",
  "bin": {
    "localmd": "src/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun test",
    "prepublishOnly": "bun run check"
  },
  "keywords": [
    "markdown",
    "editor",
    "local",
    "server",
    "preview",
    "cli"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamtamchik/localmd.git"
  },
  "bugs": {
    "url": "https://github.com/tamtamchik/localmd/issues"
  },
  "homepage": "https://github.com/tamtamchik/localmd#readme",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "7.0.2"
  }
}
